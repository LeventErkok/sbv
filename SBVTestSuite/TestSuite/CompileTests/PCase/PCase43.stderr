PCase43.hs:(18,15)-(24,9): Splicing expression
    ghc-internal:GHC.Internal.TH.Quote.quoteExp
      pCase
      " e of\n\
      \         Zero              -> e .== e =: qed\n\
      \         Num _             -> e .== e =: qed\n\
      \         Var _             -> e .== e =: qed\n\
      \         Add a _ | isZero a -> e .== e =: qed\n\
      \         Let _ _ _         -> e .== e =: qed\n\
      \       "
  ======>
    cases
      [(isZero e ==> (e .== e =: qed)), (isNum e ==> (e .== e =: qed)),
       (isVar e ==> (e .== e =: qed)),
       ((.&&) (isAdd e) (let a = getAdd_1 e in isZero a)
          ==> (e .== e =: qed)),
       (isLet e ==> (e .== e =: qed))]
